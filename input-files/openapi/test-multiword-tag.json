{
  "openapi": "3.0.0",
  "info": {
    "title": "Multi-word Tag Sample",
    "version": "1.0.0"
  },
  "paths": {
    "/widgets": {
      "get": {
        "tags": ["TagWithMultipleWords"],
        "summary": "List Widgets",
        "operationId": "ListWidgets",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/WidgetDTO" }
                }
              }
            }
          }
        }
      }
    },
    "/keys": {
      "get": {
        "tags": ["APIKeyManager"],
        "summary": "List Keys",
        "operationId": "ListKeys",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WidgetDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        },
        "required": ["id", "name"]
      }
    }
  }
}
